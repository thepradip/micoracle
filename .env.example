# Copy this file to `.env` and edit the values. Everything is optional —
# leaving a variable unset falls back to sensible per-OS defaults.

# ───────────────────────── Backends ─────────────────────────
# VOICE_AGENT_STT_BACKEND: auto | mlx | faster | openai | azure
# VOICE_AGENT_TTS_BACKEND: auto | say | pyttsx3 | openai | azure | none
# "auto" picks MLX+say on Apple Silicon, faster-whisper+pyttsx3 elsewhere.
# VOICE_AGENT_STT_BACKEND=auto
# VOICE_AGENT_TTS_BACKEND=auto

# ───────────────────────── Audio / target ───────────────────
# Mic device name fragment or numeric id (run --list-devices).
# VOICE_AGENT_INPUT_DEVICE=MacBook Pro Microphone
#
# Pin dispatch to a specific app. If unset, whatever is frontmost at startup
# is captured. On Wayland this variable is REQUIRED (no frontmost detection).
# Examples: Terminal, iTerm2, Claude, gnome-terminal, WindowsTerminal.exe
# VOICE_AGENT_TARGET_APP=Terminal

# ───────────────────────── Local STT knobs ──────────────────
# MLX Whisper model repo (Apple Silicon only).
VOICE_AGENT_MLX_REPO=mlx-community/whisper-medium.en-mlx-4bit

# faster-whisper tuning.
# Model name: tiny.en / base.en / small.en / medium.en / large-v3
VOICE_AGENT_FASTER_MODEL=small.en
# Device: auto / cpu / cuda
VOICE_AGENT_FASTER_DEVICE=auto
# Compute type: int8 (CPU-friendly) / float16 (GPU) / int8_float16
VOICE_AGENT_FASTER_COMPUTE=int8

# Faster HuggingFace downloads (one-time model pulls).
HF_HUB_ENABLE_HF_TRANSFER=1

# ───────────────────────── Cloud STT: OpenAI ────────────────
# OPENAI_API_KEY=sk-...
# VOICE_AGENT_OPENAI_STT_MODEL=whisper-1

# ───────────────────────── Cloud STT: Azure OpenAI ──────────
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# AZURE_OPENAI_KEY=...
# AZURE_WHISPER_DEPLOYMENT=whisper

# ───────────────────────── Cloud TTS: OpenAI ────────────────
# Uses OPENAI_API_KEY above. Voices: alloy, echo, fable, onyx, nova, shimmer.
# VOICE_AGENT_OPENAI_TTS_VOICE=alloy

# ───────────────────────── Cloud TTS: Azure Speech ──────────
# Separate service from Azure OpenAI.
# AZURE_SPEECH_KEY=...
# AZURE_SPEECH_REGION=eastus
# VOICE_AGENT_AZURE_TTS_VOICE=en-US-AriaNeural

# ───────────────────────── Local TTS knobs ──────────────────
# macOS `say` voice name (e.g. "Ava (Premium)"). Leave unset for default.
# VOICE_AGENT_TTS_VOICE=Samantha
